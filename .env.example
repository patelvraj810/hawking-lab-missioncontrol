# Mission Control Dashboard - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Required: Supabase Configuration
# =============================================================================

# Your Supabase project URL (found in Project Settings > API)
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Your Supabase anonymous/public key (found in Project Settings > API)
# This is safe to expose in client-side code
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key-here"

# Your Supabase project ID (used by CLI tools)
VITE_SUPABASE_PROJECT_ID="your-project-id"

# =============================================================================
# Optional: Feature Flags
# =============================================================================

# Use mock data instead of real Supabase data (default: false)
# Set to 'true' for local development without a database
# VITE_USE_MOCK=false

# Enable real-time subscriptions (default: true when not using mock data)
# Set to 'false' to disable real-time updates
# VITE_ENABLE_REALTIME=true

# Enable debug logging (default: false)
# Set to 'true' for verbose console output during development
# VITE_DEBUG=false

# Enable analytics tracking (default: false)
# VITE_ENABLE_ANALYTICS=false

# =============================================================================
# Example Configuration
# =============================================================================
# VITE_SUPABASE_URL="https://ijrevkbirborknukwaku.supabase.co"
# VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
# VITE_SUPABASE_PROJECT_ID="ijrevkbirborknukwaku"
# VITE_USE_MOCK=false
# VITE_ENABLE_REALTIME=true
# VITE_DEBUG=false